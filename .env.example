# ─── Aociety 环境配置 ──────────────────────────────────────────

# GLM 5.2 API (从环境变量读取，也可在此硬编码)
BIGMODEL_API_KEY=
GLM_MODEL_ID=glm-5.2
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ─── 服务端口 ────────────────────────────────────────────────
AOCIETY_PORT=8000
R1_OMNI_PORT=8001
AROUSAL_PORT=8002

# ─── 功能开关 ────────────────────────────────────────────────
ENABLE_EMOTION=1
ENABLE_CAMERA=1
ENABLE_MIC=1

# ─── 世界引擎 ──────────────────────────────────────────────
WORLD_PULSE_SECONDS=60

# ─── R1-Omni ──────────────────────────────────────────────
R1_OMNI_MODEL_PATH=models/r1-omni-0.5b

# ─── Arousal ─────────────────────────────────────────────────
AROUSAL_MODEL_PATH=models/arousal

# ─── 摄像头 ─────────────────────────────────────────────────
CAMERA_ID=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15

# ─── 麦克风 ─────────────────────────────────────────────────
MIC_SAMPLE_RATE=16000
MIC_CHUNK_SECONDS=1.0
